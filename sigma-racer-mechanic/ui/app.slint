import { SigmaTheme } from "theme.slint";
import { AppTitle } from "widgets/brand.slint";
import { FileLoadButton } from "widgets/common.slint";
import { Mdf4Tab } from "tabs/mdf4_tab.slint";
import { LiveTab } from "tabs/live_tab.slint";
import { DbcTab } from "tabs/dbc_tab.slint";
import { AboutTab } from "tabs/about_tab.slint";
import { DbcCatalogDialog } from "widgets/dbc_catalog.slint";
import { FrameRow, SignalRow, LiveMessageRow, LiveSignalRow, LiveFrameRow, LiveErrorRow, DbcMessageRow, DbcSignalRow, DbcNodeRow, DbcAttributeRow, DbcValueDescRow, DbcBitRow, DbcBitBand, DepRow, DbcCatalogRow } from "widgets/common.slint";

import { ConnectTab } from "tabs/connect_tab.slint";
import { DiagnosisTab, VitalRow } from "tabs/diagnosis_tab.slint";
import { MaintenanceTab } from "tabs/maintenance_tab.slint";
import { SettingsTab, SettingRow } from "tabs/settings_tab.slint";
import { UpdatesTab } from "tabs/updates_tab.slint";
import { LogsTab } from "tabs/logs_tab.slint";

export { VitalRow, SettingRow }

// Tab indices:
// 0 Connect, 1 Diagnosis, 2 Maintenance, 3 Settings, 4 Updates, 5 Logs,
// 6 MDF4, 7 Live, 8 DBC, 9 About

export component SigmaRacerMechanic inherits Window {
    title: "Sigma Racer Mechanic";
    preferred-width: 1360px;
    preferred-height: 860px;
    background: SigmaTheme.background;

    in-out property <string> status-text: "Ready";
    in-out property <string> version-text: "0.3.0";
    in-out property <int> active-tab: 0;

    // —— Vehicle ——
    callback refresh-interfaces();
    callback connect-vehicle();
    callback disconnect-vehicle();
    in-out property <[string]> vehicle-interfaces;
    in-out property <int> vehicle-selected-interface: 0;
    in-out property <int> vehicle-selected-transport: 0;
    in-out property <string> vehicle-bitrate: "500000";
    in-out property <string> vehicle-wifi-host: "";
    in-out property <string> vehicle-wifi-port: "7357";
    in-out property <bool> vehicle-use-m7-dbc: true;
    in-out property <bool> vehicle-record-session: true;
    in-out property <bool> vehicle-connected: false;
    in-out property <string> vehicle-status-label: "Disconnected";
    in-out property <string> vehicle-status-detail: "";

    in-out property <string> diag-status: "Not connected";
    in-out property <string> diag-rpm: "—";
    in-out property <string> diag-coolant: "—";
    in-out property <string> diag-oil: "—";
    in-out property <string> diag-dtc: "—";
    in-out property <string> diag-gear: "—";
    in-out property <string> diag-side-stand: "—";
    in-out property <string> diag-mode: "—";
    in-out property <string> diag-frame-count: "0";
    in-out property <[VitalRow]> diag-vitals;

    callback maintenance-reset-service();
    callback maintenance-reset-oil();
    callback maintenance-clear-warning();
    in-out property <string> maintenance-status: "Protocol pending with Wingman firmware.";

    callback refresh-settings();
    in-out property <string> settings-status: "";
    in-out property <[SettingRow]> vehicle-settings;

    callback check-updates();
    callback download-bundle();
    in-out property <string> ota-channel: "dev";
    in-out property <string> ota-current: "0.0.0";
    in-out property <string> ota-available: "";
    in-out property <string> ota-notes: "";
    in-out property <string> ota-bundle-url: "";
    in-out property <bool> ota-update-available: false;
    in-out property <bool> ota-busy: false;
    in-out property <string> ota-status: "";

    callback request-ecu-log();
    callback open-local-mdf4-from-logs();
    callback replay-session();
    callback stop-replay();
    in-out property <string> logs-status: "Record WiFi sessions from Connect, replay saved .jsonl files, or import MDF4 for CAN analysis.";
    in-out property <bool> logs-replay-active: false;

    // —— Analysis (same surface as can-viewer) ——
    callback open-mdf4();
    callback mdf4-open-dbc();
    callback export-mdf4();
    callback apply-filters();
    callback clear-filters();
    callback frame-selected(int);
    in-out property <string> mdf4-path: "";
    in-out property <string> mdf4-file-name: "";
    in-out property <string> mdf4-dbc-status: "No DBC";
    in-out property <string> mdf4-dbc-file-name: "";
    in-out property <string> mdf4-frame-count: "Loaded 0 / 0 frames";
    in-out property <[FrameRow]> mdf4-frames;
    in-out property <[SignalRow]> mdf4-signals;
    in-out property <string> mdf4-filter-can-id: "";
    in-out property <string> mdf4-filter-message: "";
    in-out property <string> mdf4-filter-data: "";
    in-out property <int> mdf4-selected-frame: -1;

    callback refresh-interfaces-live();
    callback start-capture();
    callback stop-capture();
    callback export-capture();
    in-out property <[string]> live-interfaces;
    in-out property <int> live-selected-interface: 0;
    in-out property <bool> live-capturing: false;
    in-out property <string> live-capture-status: "Stopped";
    in-out property <string> live-stats-text: "";
    in-out property <bool> live-linux-only: true;
    in-out property <[LiveMessageRow]> live-messages;
    in-out property <[LiveSignalRow]> live-signals;
    in-out property <[LiveFrameRow]> live-frames;
    in-out property <[LiveErrorRow]> live-errors;
    in-out property <int> live-view: 0;

    callback new-dbc();
    callback begin-edit();
    callback undo-dbc();
    callback save-dbc();
    callback save-dbc-as();
    callback field-edited();
    callback add-message();
    callback delete-message();
    callback add-signal();
    callback delete-signal();
    callback add-node();
    callback delete-node();
    callback message-selected(int);
    callback signal-selected(int);
    callback node-selected(int);
    callback refresh-bit-map();
    callback bit-cell-clicked(int);
    in-out property <string> dbc-path: "";
    in-out property <bool> dbc-dirty: false;
    in-out property <string> dbc-version: "";
    in-out property <string> dbc-comment: "";
    in-out property <[DbcMessageRow]> dbc-messages;
    in-out property <[DbcSignalRow]> dbc-signals;
    in-out property <[DbcNodeRow]> dbc-nodes;
    in-out property <[DbcAttributeRow]> dbc-attributes;
    in-out property <[DbcValueDescRow]> dbc-value-descriptions;
    in-out property <[DbcBitBand]> dbc-bit-bands;
    in-out property <string> dbc-bit-summary: "";
    in-out property <int> dbc-bit-dlc: 0;
    in-out property <int> dbc-selected-message: -1;
    in-out property <int> dbc-selected-signal: -1;
    in-out property <int> dbc-selected-node: -1;
    in-out property <string> dbc-edit-message-id: "";
    in-out property <string> dbc-edit-message-name: "";
    in-out property <string> dbc-edit-message-dlc: "8";
    in-out property <string> dbc-edit-message-sender: "";
    in-out property <string> dbc-edit-signal-name: "";
    in-out property <string> dbc-edit-signal-start: "0";
    in-out property <string> dbc-edit-signal-length: "8";
    in-out property <string> dbc-edit-signal-factor: "1";
    in-out property <string> dbc-edit-signal-offset: "0";
    in-out property <string> dbc-edit-signal-unit: "";
    in-out property <string> dbc-edit-signal-byte-order: "Intel";
    in-out property <string> dbc-edit-node-name: "";
    in-out property <string> dbc-edit-node-comment: "";
    in-out property <int> dbc-editor-panel: 0;
    in-out property <bool> dbc-editing: false;

    in-out property <string> about-copyright: "";
    in-out property <string> about-license-notice: "";
    in-out property <string> about-credits: "";
    in-out property <string> about-transitive-summary: "";
    in-out property <[string]> about-notice-lines;
    in-out property <[DepRow]> about-direct-deps;

    callback open-dbc-catalog();
    callback dbc-catalog-refresh();
    callback dbc-catalog-load();
    callback dbc-catalog-close();
    callback set-dbc-catalog-selected(int);
    in-out property <bool> dbc-catalog-open: false;
    in-out property <bool> dbc-catalog-busy: false;
    in-out property <string> dbc-catalog-status: "";
    in-out property <int> dbc-catalog-selected: -1;
    in-out property <[DbcCatalogRow]> dbc-catalog-files;

    private property <[string]> tab-labels:
        ["Connect", "Diagnosis", "Maintenance", "Settings", "Updates", "Logs", "MDF4", "Live", "DBC", "About"];

    main-layer := Rectangle {
        width: 100%;
        height: 100%;
        VerticalLayout {
            padding: 8px;
            spacing: 8px;

            header-bar := Rectangle {
                height: 36px;
                width: 100%;
                background: SigmaTheme.surface-raised;
                border-radius: 4px;

                left-header := HorizontalLayout {
                    x: 8px;
                    y: (parent.height - self.height) / 2;
                    height: 28px;
                    width: min(parent.width - 200px, self.preferred-width);
                    spacing: 6px;
                    alignment: center;
                    AppTitle { title: "Mechanic"; }
                    Rectangle { width: 1px; height: 18px; background: SigmaTheme.border; }
                    for tab-label[i] in root.tab-labels: Rectangle {
                        height: 24px;
                        min-width: 52px;
                        background: root.active-tab == i
                            ? SigmaTheme.accent.transparentize(0.7)
                            : (touch.has-hover ? SigmaTheme.surface : transparent);
                        border-radius: 4px;
                        border-width: root.active-tab == i ? 1px : 0px;
                        border-color: SigmaTheme.accent;
                        touch := TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { root.active-tab = i; }
                        }
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            alignment: center;
                            Text {
                                text: tab-label;
                                color: root.active-tab == i ? SigmaTheme.accent : SigmaTheme.text-dim;
                                font-weight: root.active-tab == i ? 700 : 400;
                                vertical-alignment: center;
                                font-size: SigmaTheme.font-size-small;
                            }
                        }
                    }
                }

                right-header := HorizontalLayout {
                    x: parent.width - self.width - 8px;
                    y: (parent.height - self.height) / 2;
                    height: 28px;
                    width: self.preferred-width;
                    spacing: 6px;
                    FileLoadButton {
                        label: "MDF4";
                        filename: root.mdf4-file-name;
                        loaded: root.mdf4-path != "";
                        clicked => { root.open-mdf4(); }
                    }
                    FileLoadButton {
                        label: "DBC";
                        filename: root.mdf4-dbc-file-name;
                        loaded: root.mdf4-dbc-status != "No DBC";
                        clicked => { root.mdf4-open-dbc(); }
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                clip: true;

                if root.active-tab == 0: ConnectTab {
                    width: 100%; height: 100%;
                    selected-transport <=> root.vehicle-selected-transport;
                    interfaces <=> root.vehicle-interfaces;
                    selected-interface <=> root.vehicle-selected-interface;
                    bitrate-text <=> root.vehicle-bitrate;
                    wifi-host <=> root.vehicle-wifi-host;
                    wifi-port <=> root.vehicle-wifi-port;
                    use-m7-dbc <=> root.vehicle-use-m7-dbc;
                    record-session <=> root.vehicle-record-session;
                    connected <=> root.vehicle-connected;
                    status-label <=> root.vehicle-status-label;
                    status-detail <=> root.vehicle-status-detail;
                    refresh-interfaces => { root.refresh-interfaces(); }
                    connect-vehicle => { root.connect-vehicle(); }
                    disconnect-vehicle => { root.disconnect-vehicle(); }
                }
                if root.active-tab == 1: DiagnosisTab {
                    width: 100%; height: 100%;
                    connected: root.vehicle-connected;
                    status-text: root.diag-status;
                    rpm: root.diag-rpm;
                    coolant: root.diag-coolant;
                    oil-temp: root.diag-oil;
                    dtc-count: root.diag-dtc;
                    gear: root.diag-gear;
                    side-stand: root.diag-side-stand;
                    performance-mode: root.diag-mode;
                    frame-count: root.diag-frame-count;
                    vitals: root.diag-vitals;
                }
                if root.active-tab == 2: MaintenanceTab {
                    width: 100%; height: 100%;
                    connected: root.vehicle-connected;
                    status-text: root.maintenance-status;
                    reset-service => { root.maintenance-reset-service(); }
                    reset-oil => { root.maintenance-reset-oil(); }
                    clear-warning => { root.maintenance-clear-warning(); }
                }
                if root.active-tab == 3: SettingsTab {
                    width: 100%; height: 100%;
                    connected: root.vehicle-connected;
                    status-text: root.settings-status;
                    settings: root.vehicle-settings;
                    refresh-settings => { root.refresh-settings(); }
                }
                if root.active-tab == 4: UpdatesTab {
                    width: 100%; height: 100%;
                    channel: root.ota-channel;
                    current-version: root.ota-current;
                    available-version: root.ota-available;
                    notes: root.ota-notes;
                    bundle-url: root.ota-bundle-url;
                    update-available: root.ota-update-available;
                    busy: root.ota-busy;
                    status-text: root.ota-status;
                    check-updates => { root.check-updates(); }
                    download-bundle => { root.download-bundle(); }
                }
                if root.active-tab == 5: LogsTab {
                    width: 100%; height: 100%;
                    status-text: root.logs-status;
                    replay-active: root.logs-replay-active;
                    replay-session => { root.replay-session(); }
                    stop-replay => { root.stop-replay(); }
                    open-local-mdf4 => { root.open-local-mdf4-from-logs(); }
                }
                if root.active-tab == 6: Mdf4Tab {
                    width: 100%; height: 100%;
                    mdf4-path <=> root.mdf4-path;
                    frame-count <=> root.mdf4-frame-count;
                    frames <=> root.mdf4-frames;
                    signals <=> root.mdf4-signals;
                    filter-can-id <=> root.mdf4-filter-can-id;
                    filter-message <=> root.mdf4-filter-message;
                    filter-data <=> root.mdf4-filter-data;
                    selected-frame-index <=> root.mdf4-selected-frame;
                    export-mdf4 => { root.export-mdf4(); }
                    apply-filters => { root.apply-filters(); }
                    clear-filters => { root.clear-filters(); }
                    frame-selected(index) => { root.frame-selected(index); }
                }
                if root.active-tab == 7: LiveTab {
                    width: 100%; height: 100%;
                    interfaces <=> root.live-interfaces;
                    selected-interface <=> root.live-selected-interface;
                    capturing <=> root.live-capturing;
                    capture-status <=> root.live-capture-status;
                    stats-text <=> root.live-stats-text;
                    linux-only <=> root.live-linux-only;
                    messages <=> root.live-messages;
                    signals <=> root.live-signals;
                    frames <=> root.live-frames;
                    errors <=> root.live-errors;
                    live-view <=> root.live-view;
                    refresh-interfaces => { root.refresh-interfaces-live(); }
                    start-capture => { root.start-capture(); }
                    stop-capture => { root.stop-capture(); }
                    export-capture => { root.export-capture(); }
                }
                if root.active-tab == 8: DbcTab {
                    width: 100%; height: 100%;
                    dbc-path <=> root.dbc-path;
                    dirty <=> root.dbc-dirty;
                    version <=> root.dbc-version;
                    comment <=> root.dbc-comment;
                    messages <=> root.dbc-messages;
                    signals <=> root.dbc-signals;
                    nodes <=> root.dbc-nodes;
                    attributes <=> root.dbc-attributes;
                    value-descriptions <=> root.dbc-value-descriptions;
                    bit-bands <=> root.dbc-bit-bands;
                    bit-summary <=> root.dbc-bit-summary;
                    bit-dlc <=> root.dbc-bit-dlc;
                    selected-message <=> root.dbc-selected-message;
                    selected-signal <=> root.dbc-selected-signal;
                    selected-node <=> root.dbc-selected-node;
                    edit-message-id <=> root.dbc-edit-message-id;
                    edit-message-name <=> root.dbc-edit-message-name;
                    edit-message-dlc <=> root.dbc-edit-message-dlc;
                    edit-message-sender <=> root.dbc-edit-message-sender;
                    edit-signal-name <=> root.dbc-edit-signal-name;
                    edit-signal-start <=> root.dbc-edit-signal-start;
                    edit-signal-length <=> root.dbc-edit-signal-length;
                    edit-signal-factor <=> root.dbc-edit-signal-factor;
                    edit-signal-offset <=> root.dbc-edit-signal-offset;
                    edit-signal-unit <=> root.dbc-edit-signal-unit;
                    edit-signal-byte-order <=> root.dbc-edit-signal-byte-order;
                    edit-node-name <=> root.dbc-edit-node-name;
                    edit-node-comment <=> root.dbc-edit-node-comment;
                    editor-panel <=> root.dbc-editor-panel;
                    editing <=> root.dbc-editing;
                    new-dbc => { root.new-dbc(); }
                    open-dbc-catalog => { root.open-dbc-catalog(); }
                    begin-edit => { root.begin-edit(); }
                    undo-dbc => { root.undo-dbc(); }
                    open-dbc => { root.mdf4-open-dbc(); }
                    save-dbc => { root.save-dbc(); }
                    save-dbc-as => { root.save-dbc-as(); }
                    field-edited => { root.field-edited(); }
                    add-message => { root.add-message(); }
                    delete-message => { root.delete-message(); }
                    add-signal => { root.add-signal(); }
                    delete-signal => { root.delete-signal(); }
                    add-node => { root.add-node(); }
                    delete-node => { root.delete-node(); }
                    message-selected(index) => { root.message-selected(index); }
                    signal-selected(index) => { root.signal-selected(index); }
                    node-selected(index) => { root.node-selected(index); }
                    refresh-bit-map => { root.refresh-bit-map(); }
                    bit-cell-clicked(index) => { root.bit-cell-clicked(index); }
                }
                if root.active-tab == 9: AboutTab {
                    width: 100%; height: 100%;
                    version-text: root.version-text;
                    copyright-text: root.about-copyright;
                    license-notice: root.about-license-notice;
                    credits-text: root.about-credits;
                    transitive-summary: root.about-transitive-summary;
                    notice-lines: root.about-notice-lines;
                    direct-deps: root.about-direct-deps;
                }
            }
        }

        DbcCatalogDialog {
            width: 100%;
            height: 100%;
            open <=> root.dbc-catalog-open;
            busy <=> root.dbc-catalog-busy;
            status-text <=> root.dbc-catalog-status;
            selected-index <=> root.dbc-catalog-selected;
            files <=> root.dbc-catalog-files;
            close => { root.dbc-catalog-close(); }
            refresh => { root.dbc-catalog-refresh(); }
            load-selected => { root.dbc-catalog-load(); }
            file-selected(index) => { root.set-dbc-catalog-selected(index); }
        }
    }
}
