import { SigmaTheme } from "theme.slint";
import { ToolbarButton } from "widgets/common.slint";

export component LogsTab inherits Rectangle {
    callback request-ecu-log();
    callback open-local-mdf4();
    callback replay-session();
    callback stop-replay();

    in property <string> status-text: "Record WiFi sessions from Connect, replay saved .jsonl files, or import MDF4 for CAN analysis.";
    in property <bool> replay-active: false;

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 12px;
        spacing: 10px;
        Text {
            text: "Logs & sessions";
            color: SigmaTheme.text;
            font-weight: 700;
        }
        Text {
            text: "WiFi telemetry sessions are saved as NDJSON under ~/.config/sigma-racer-mechanic/sessions/. Replay drives the Diagnosis tab; import MDF4 for raw CAN analysis.";
            color: SigmaTheme.text-dim;
            wrap: word-wrap;
            font-size: SigmaTheme.font-size-small;
        }
        HorizontalLayout {
            spacing: 8px;
            ToolbarButton {
                label: "Replay session…";
                enabled: !root.replay-active;
                clicked => { root.replay-session(); }
            }
            ToolbarButton {
                label: "Stop replay";
                enabled: root.replay-active;
                clicked => { root.stop-replay(); }
            }
            ToolbarButton {
                label: "Open local MDF4…";
                clicked => { root.open-local-mdf4(); }
            }
        }
        Text {
            text: root.status-text;
            color: SigmaTheme.text-dim;
            wrap: word-wrap;
            font-size: SigmaTheme.font-size-small;
        }
    }
}
