import { ListView, LineEdit } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";
import { FrameRow, SignalRow, ToolbarButton, StatusChip } from "../widgets/common.slint";

export component Mdf4Tab inherits Rectangle {
    callback open-mdf4();
    callback open-dbc();
    callback open-catalog();
    callback export-mdf4();
    callback apply-filters();
    callback clear-filters();
    callback frame-selected(int);

    in-out property <string> mdf4-path: "";
    in-out property <string> dbc-status: "No DBC";
    in-out property <string> frame-count: "0 frames";
    in-out property <[FrameRow]> frames;
    in-out property <[SignalRow]> signals;
    in-out property <string> filter-can-id: "";
    in-out property <string> filter-message: "";
    in-out property <string> filter-data: "";
    in-out property <int> selected-frame-index: -1;

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;
            ToolbarButton { label: "Open MDF4"; clicked => { root.open-mdf4(); } }
            ToolbarButton { label: "Open DBC"; clicked => { root.open-dbc(); } }
            ToolbarButton { label: "Catalog"; clicked => { root.open-catalog(); } }
            ToolbarButton { label: "Export"; clicked => { root.export-mdf4(); } }
            StatusChip { label: "DBC"; value: root.dbc-status; }
            StatusChip { label: "File"; value: root.mdf4-path == "" ? "—" : root.mdf4-path; }
            Rectangle { horizontal-stretch: 1; }
            Text { text: root.frame-count; color: SigmaTheme.text-dim; vertical-alignment: center; }
        }

        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 1;

            Rectangle {
                horizontal-stretch: 3;
                background: SigmaTheme.surface;
                border-radius: 4px;
                border-width: 1px;
                border-color: SigmaTheme.border;

                VerticalLayout {
                    padding: 4px;
                    Rectangle {
                        height: 28px;
                        background: SigmaTheme.surface-raised;
                        HorizontalLayout {
                            padding-left: 8px;
                            spacing: 8px;
                            Text { text: "#"; width: 40px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                            Text { text: "Timestamp"; width: 100px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                            Text { text: "CAN ID"; width: 80px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                            Text { text: "Ch"; width: 30px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                            Text { text: "DLC"; width: 30px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                            Text { text: "Data"; horizontal-stretch: 1; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                            Text { text: "Message"; width: 120px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                        }
                    }
                    ListView {
                        for row[i] in root.frames: Rectangle {
                            height: SigmaTheme.row-height;
                            background: i == root.selected-frame-index ? SigmaTheme.accent.transparentize(0.85) : (touch.has-hover ? SigmaTheme.surface-raised : transparent);
                            touch := TouchArea {
                                clicked => { root.frame-selected(i); }
                            }
                            HorizontalLayout {
                                padding-left: 8px;
                                spacing: 8px;
                                Text { text: row.index; width: 40px; color: SigmaTheme.text; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                Text { text: row.timestamp; width: 100px; color: SigmaTheme.text; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                Text { text: row.can-id; width: 80px; color: SigmaTheme.accent-amber; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                Text { text: row.channel; width: 30px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                Text { text: row.dlc; width: 30px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                Text { text: row.data-hex; horizontal-stretch: 1; color: SigmaTheme.text; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                Text { text: row.message-name; width: 120px; color: SigmaTheme.accent-green; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                min-width: 240px;
                spacing: 8px;

                Rectangle {
                    background: SigmaTheme.surface;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: SigmaTheme.border;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 8px;
                        Text { text: "Filters"; color: SigmaTheme.text; font-weight: 600; }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "CAN ID"; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; }
                            LineEdit {
                                min-height: 28px;
                                text <=> root.filter-can-id;
                                placeholder-text: "e.g. 0x123 or comma-separated";
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "Message"; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; }
                            LineEdit {
                                min-height: 28px;
                                text <=> root.filter-message;
                                placeholder-text: "Message name";
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "Data (hex)"; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; }
                            LineEdit {
                                min-height: 28px;
                                text <=> root.filter-data;
                                placeholder-text: "Data hex filter";
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            ToolbarButton { label: "Apply"; clicked => { root.apply-filters(); } }
                            ToolbarButton { label: "Clear"; clicked => { root.clear-filters(); } }
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                    background: SigmaTheme.surface;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: SigmaTheme.border;
                    VerticalLayout {
                        padding: 4px;
                        Text { text: "Signals"; color: SigmaTheme.text; font-weight: 600; padding: 4px; }
                        ListView {
                            for sig in root.signals: Rectangle {
                                height: SigmaTheme.row-height;
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 8px;
                                    Text { text: sig.signal-name; width: 100px; color: SigmaTheme.accent; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                    Text { text: sig.value; width: 80px; color: SigmaTheme.text; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                    Text { text: sig.unit; width: 40px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                    Text { text: sig.raw-value; width: 60px; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                    Text { text: sig.description; horizontal-stretch: 1; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
