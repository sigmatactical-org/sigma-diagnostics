import { ListView } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";
import { DbcCatalogRow, ToolbarButton } from "./common.slint";

export component DbcCatalogDialog inherits Rectangle {
    callback close();
    callback refresh();
    callback load-selected();
    callback file-selected(int);

    in property <bool> open: false;
    in property <bool> busy: false;
    in property <string> status-text: "";
    in-out property <int> selected-index: -1;
    in-out property <[DbcCatalogRow]> files;

    if root.open: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000088;

        TouchArea {
            clicked => { root.close(); }
        }

        Rectangle {
            width: 480px;
            height: 360px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: SigmaTheme.surface-raised;
            border-radius: 6px;
            border-width: 1px;
            border-color: SigmaTheme.border;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                Text {
                    text: "Sigma Racer DBC Catalog";
                    color: SigmaTheme.text;
                    font-weight: 600;
                }

                Text {
                    text: root.status-text;
                    color: SigmaTheme.text-dim;
                    font-size: SigmaTheme.font-size-small;
                    wrap: word-wrap;
                }

                Rectangle {
                    vertical-stretch: 1;
                    background: SigmaTheme.surface;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: SigmaTheme.border;

                    if root.files.length == 0: VerticalLayout {
                        alignment: center;
                        Text {
                            text: root.busy ? "Loading…" : "No schemas found";
                            color: SigmaTheme.text-dim;
                            horizontal-alignment: center;
                        }
                    }

                    if root.files.length > 0: ListView {
                        for row[i] in root.files: Rectangle {
                            height: SigmaTheme.row-height;
                            background: i == root.selected-index
                                ? SigmaTheme.accent.transparentize(0.85)
                                : (touch.has-hover ? SigmaTheme.surface-raised : transparent);
                            touch := TouchArea {
                                clicked => { root.file-selected(i); }
                            }
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 12px;
                                Text {
                                    text: row.name;
                                    color: SigmaTheme.text;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.filename;
                                    color: SigmaTheme.text-dim;
                                    width: 140px;
                                    font-size: SigmaTheme.font-size-small;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: row.size-text;
                                    color: SigmaTheme.text-dim;
                                    width: 64px;
                                    font-size: SigmaTheme.font-size-small;
                                    horizontal-alignment: right;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    ToolbarButton {
                        label: "Refresh";
                        clicked => { root.refresh(); }
                    }
                    ToolbarButton {
                        label: "Load";
                        clicked => { root.load-selected(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    ToolbarButton {
                        label: "Close";
                        clicked => { root.close(); }
                    }
                }
            }
        }
    }
}
