export global SigmaTheme {
    in-out property <brush> background: #141414;
    in-out property <brush> surface: #1e1e1e;
    in-out property <brush> surface-raised: #2a2a2a;
    in-out property <brush> border: #3a3a3a;
    in-out property <brush> text: #e8e8e8;
    in-out property <brush> text-dim: #9a9a9a;
    in-out property <brush> accent: #3b82f6;
    in-out property <brush> accent-amber: #f59e0b;
    in-out property <brush> accent-red: #ef4444;
    in-out property <brush> accent-green: #22c55e;
    in-out property <length> font-size: 13px;
    in-out property <length> font-size-small: 11px;
    in-out property <length> row-height: 28px;
}
