import { ListView } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";
import {
    AnalyzeIdRow, AnalyzeBitCell, AnalyzeBitRow, AnalyzeFactRow,
    Cell, HeaderCell, TableHeader, TableRow, EmptyState, ToolbarButton
} from "../widgets/common.slint";

// Empirical bit cell: colored by observed activity.
component BitPip inherits Rectangle {
    in property <int> state;
    width: 16px;
    height: 16px;
    border-radius: 2px;
    border-width: 1px;
    border-color: SigmaTheme.border;
    // 0 const-0 (dim), 1 const-1 (solid), 2 toggles (accent), 3 unobserved (faint)
    background: root.state == 2
        ? SigmaTheme.accent
        : (root.state == 1
            ? SigmaTheme.text-dim
            : (root.state == 3 ? transparent : SigmaTheme.surface-raised));
    Text {
        text: root.state == 2 ? "~" : (root.state == 1 ? "1" : (root.state == 3 ? "" : "0"));
        color: root.state == 2 ? SigmaTheme.background : SigmaTheme.text-dim;
        font-size: SigmaTheme.font-size-small;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component AnalyzeTab inherits Rectangle {
    callback run-analysis();
    callback id-selected(int);

    in-out property <string> status: "";
    in-out property <bool> analyzed: false;
    in-out property <[AnalyzeIdRow]> ids;
    in-out property <int> selected-id: -1;
    in-out property <string> detail-title: "";
    in-out property <[AnalyzeBitRow]> bit-rows;
    in-out property <[AnalyzeFactRow]> facts;

    background: SigmaTheme.background;

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 8px;
            ToolbarButton {
                label: "Analyze loaded log";
                clicked => { root.run-analysis(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: root.status;
                color: SigmaTheme.text-dim;
                vertical-alignment: center;
            }
        }

        HorizontalLayout {
            spacing: 8px;
            vertical-stretch: 1;

            // Left: per-ID survey table.
            Rectangle {
                horizontal-stretch: 3;
                background: SigmaTheme.surface;
                border-radius: 4px;
                border-width: 1px;
                border-color: SigmaTheme.border;

                if !root.analyzed: EmptyState {
                    message: "No analysis yet";
                    hint: "Load an MDF4 log with the header button, then click \"Analyze loaded log\". Every reported fact is proven over all frames of the ID.";
                }

                if root.analyzed: VerticalLayout {
                    padding: 6px;
                    spacing: 4px;
                    TableHeader {
                        HeaderCell { text: "CAN ID"; width: 84px; }
                        HeaderCell { text: "Frames"; width: 70px; }
                        HeaderCell { text: "Period"; width: 96px; }
                        HeaderCell { text: "Distinct"; width: 70px; }
                        HeaderCell { text: "Proven facts"; horizontal-stretch: 1; }
                    }
                    ListView {
                        for row[i] in root.ids: TableRow {
                            selected: i == root.selected-id;
                            clicked => { root.id-selected(i); }
                            Cell { text: row.can-id; width: 84px; font-weight: 600; }
                            Cell { text: row.frames; width: 70px; }
                            Cell { text: row.period; width: 96px; }
                            Cell { text: row.distinct; width: 70px; }
                            Cell { text: row.facts; horizontal-stretch: 1; }
                        }
                    }
                }
            }

            // Right: empirical bit grid + proven facts for the selected ID.
            Rectangle {
                horizontal-stretch: 2;
                background: SigmaTheme.surface;
                border-radius: 4px;
                border-width: 1px;
                border-color: SigmaTheme.border;

                if root.selected-id < 0: EmptyState {
                    message: "Select a CAN ID";
                    hint: "The empirical bit map shows which bits are constant (0/1) and which toggle (~), measured across every frame.";
                }

                if root.selected-id >= 0: VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    Text {
                        text: root.detail-title;
                        color: SigmaTheme.text;
                        font-weight: 700;
                    }
                    Text {
                        text: "Empirical bit activity (~ toggles · 1/0 constant)";
                        color: SigmaTheme.text-dim;
                        font-size: SigmaTheme.font-size-small;
                    }
                    for brow in root.bit-rows: HorizontalLayout {
                        spacing: 4px;
                        Text {
                            text: brow.byte-label;
                            color: SigmaTheme.text-dim;
                            font-size: SigmaTheme.font-size-small;
                            width: 52px;
                            vertical-alignment: center;
                        }
                        for cell in brow.cells: BitPip { state: cell.state; }
                    }
                    Rectangle { height: 6px; }
                    Text {
                        text: "Proven facts";
                        color: SigmaTheme.text-dim;
                        font-size: SigmaTheme.font-size-small;
                    }
                    ListView {
                        vertical-stretch: 1;
                        for fact in root.facts: HorizontalLayout {
                            padding: 2px;
                            spacing: 6px;
                            Text {
                                text: fact.kind;
                                color: SigmaTheme.accent;
                                font-size: SigmaTheme.font-size-small;
                                font-weight: 700;
                                width: 84px;
                            }
                            Text {
                                text: fact.text;
                                color: SigmaTheme.text;
                                font-size: SigmaTheme.font-size-small;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }
            }
        }
    }
}
