import { SigmaTheme } from "../theme.slint";
import { DbcBitBand, DbcBitRow } from "common.slint";

/// One byte: label + bit7…0 header + 8 cells.
component ByteBitStrip inherits VerticalLayout {
    in property <DbcBitRow> byte-data;
    callback cell-clicked(int);

    spacing: 1px;
    alignment: start;
    // 8 cells of 18px with 2px gaps; the label sits above, not beside.
    width: 8 * 18px + 7 * 2px;

    Text {
        text: root.byte-data.byte-label;
        color: SigmaTheme.text-dim;
        font-size: 9px;
        height: 12px;
    }

    HorizontalLayout {
        spacing: 2px;
        height: 12px;
        for bit-label in ["7", "6", "5", "4", "3", "2", "1", "0"]: Text {
            text: bit-label;
            width: 18px;
            height: 12px;
            color: SigmaTheme.text-dim;
            font-size: 8px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    HorizontalLayout {
        spacing: 2px;
        height: 18px;
        for cell[c] in root.byte-data.cells: Rectangle {
            width: 18px;
            height: 18px;
            border-radius: 2px;
            border-width: 1px;
            border-color: cell.state == 2
                ? SigmaTheme.accent
                : (cell.state == 3 ? SigmaTheme.accent-red : SigmaTheme.border);
            background: cell.state == 0
                ? SigmaTheme.surface
                : (cell.state == 1
                    ? SigmaTheme.surface-raised
                    : (cell.state == 2
                        ? SigmaTheme.accent.transparentize(0.45)
                        : SigmaTheme.accent-red.transparentize(0.55)));
            TouchArea {
                clicked => {
                    if cell.signal-index >= 0 {
                        root.cell-clicked(cell.signal-index);
                    }
                }
            }
        }
    }
}

/// Occupancy grid: up to 4 byte strips per row (columns), then wrap.
/// DLC 8 → 2 rows × 4 columns; DLC 4 → 1×4; DLC 3 → 1×3.
export component SignalBitMap inherits Rectangle {
    in property <[DbcBitBand]> bands;
    in property <string> summary: "";
    in property <int> dlc: 0;
    callback cell-clicked(int);

    pure function preferred-map-height() -> length {
        if root.bands.length == 0 {
            return 0px;
        }
        // summary + spacing + bands (48 each, 8 between) + spacing + legend
        return 14px + 4px
            + root.bands.length * 48px
            + max(0, root.bands.length - 1) * 8px
            + 4px + 14px;
    }

    // Thin frame around the bit analyzer; collapses when there is nothing to
    // show. The +20px accounts for the inner 10px padding top and bottom.
    // A darker fill recesses it from the raised detail box behind it.
    border-width: 1px;
    border-color: SigmaTheme.border;
    border-radius: 4px;
    background: SigmaTheme.background.transparentize(0.35);
    vertical-stretch: 0;
    height: root.bands.length == 0 ? 0px : root.preferred-map-height() + 20px;

    VerticalLayout {
        padding: 10px;
        spacing: 4px;
        alignment: start;

        Text {
            text: root.summary;
            color: SigmaTheme.text-dim;
            font-size: SigmaTheme.font-size-small;
            height: 14px;
            overflow: elide;
        }

        VerticalLayout {
            spacing: 8px;
            for band in root.bands: HorizontalLayout {
                spacing: 12px;
                alignment: start;
                for byte-row in band.bytes: ByteBitStrip {
                    byte-data: byte-row;
                    cell-clicked(sig-idx) => { root.cell-clicked(sig-idx); }
                }
            }
        }

        HorizontalLayout {
            spacing: 10px;
            alignment: start;
            height: 14px;
            HorizontalLayout {
                spacing: 4px;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    background: SigmaTheme.surface;
                    border-width: 1px;
                    border-color: SigmaTheme.border;
                    border-radius: 2px;
                }
                Text { text: "free"; color: SigmaTheme.text-dim; font-size: 9px; vertical-alignment: center; }
            }
            HorizontalLayout {
                spacing: 4px;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    background: SigmaTheme.surface-raised;
                    border-width: 1px;
                    border-color: SigmaTheme.border;
                    border-radius: 2px;
                }
                Text { text: "used"; color: SigmaTheme.text-dim; font-size: 9px; vertical-alignment: center; }
            }
            HorizontalLayout {
                spacing: 4px;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    background: SigmaTheme.accent.transparentize(0.45);
                    border-width: 1px;
                    border-color: SigmaTheme.accent;
                    border-radius: 2px;
                }
                Text { text: "selected"; color: SigmaTheme.text-dim; font-size: 9px; vertical-alignment: center; }
            }
            HorizontalLayout {
                spacing: 4px;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    background: SigmaTheme.accent-red.transparentize(0.55);
                    border-width: 1px;
                    border-color: SigmaTheme.accent-red;
                    border-radius: 2px;
                }
                Text { text: "conflict"; color: SigmaTheme.text-dim; font-size: 9px; vertical-alignment: center; }
            }
        }
    }
}
