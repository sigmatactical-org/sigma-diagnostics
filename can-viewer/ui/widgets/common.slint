import { LineEdit } from "std-widgets.slint";
import { SigmaTheme } from "../theme.slint";

export struct FrameRow {
    index: int,
    timestamp: string,
    can-id: string,
    channel: string,
    dlc: string,
    data-hex: string,
    message-name: string,
}

export struct SignalRow {
    signal-name: string,
    value: string,
    unit: string,
    raw-value: string,
    description: string,
}

export struct LiveMessageRow {
    can-id: string,
    message-name: string,
    data-hex: string,
    count: string,
    rate: string,
}

export struct LiveSignalRow {
    message-name: string,
    signal-name: string,
    value: string,
    unit: string,
    min-value: string,
    max-value: string,
}

export struct LiveFrameRow {
    timestamp: string,
    can-id: string,
    dlc: string,
    data-hex: string,
    flags: string,
}

export struct LiveErrorRow {
    timestamp: string,
    channel: string,
    error-type: string,
    details: string,
    count: string,
}

export struct DbcMessageRow {
    id: string,
    name: string,
    dlc: string,
    sender: string,
    signal-count: string,
}

export struct DbcSignalRow {
    name: string,
    start-bit: string,
    length: string,
    byte-order: string,
    factor: string,
    unit: string,
}

/// One cell in the Intel bit map. state: 0 empty, 1 other, 2 selected, 3 overflow
export struct DbcBitCell {
    state: int,
    signal-index: int,
}

/// One byte row: cells[0]=bit7 … cells[7]=bit0
export struct DbcBitRow {
    byte-label: string,
    cells: [DbcBitCell],
}

/// One horizontal band of up to 4 byte strips (4-column occupancy grid).
export struct DbcBitBand {
    bytes: [DbcBitRow],
}

export struct DbcNodeRow {
    name: string,
    comment: string,
}

export struct DbcAttributeRow {
    name: string,
    object-type: string,
    value-summary: string,
}

export struct DbcValueDescRow {
    message-id: string,
    signal-name: string,
    entries: string,
}

export struct DepRow {
    name: string,
    version: string,
    license: string,
}

/// One CAN ID in the reverse-engineering survey table.
export struct AnalyzeIdRow {
    can-id: string,
    frames: string,
    period: string,
    distinct: string,
    facts: string,
}

/// One empirical bit: state 0 const-0, 1 const-1, 2 toggles, 3 unobserved.
export struct AnalyzeBitCell {
    state: int,
}

/// One byte of the empirical activity grid: cells[0]=bit7 … cells[7]=bit0.
export struct AnalyzeBitRow {
    byte-label: string,
    cells: [AnalyzeBitCell],
}

/// A proven fact line (counter / checksum / mux / note).
export struct AnalyzeFactRow {
    kind: string,
    text: string,
}

export struct DbcCatalogRow {
    filename: string,
    name: string,
    size-text: string,
}

/// Body cell for table rows: small, vertically centered, elided.
export component Cell inherits Text {
    color: SigmaTheme.text;
    font-size: SigmaTheme.font-size-small;
    vertical-alignment: center;
    overflow: elide;
}

/// Column header cell: dim, bold variant of Cell.
export component HeaderCell inherits Cell {
    color: SigmaTheme.text-dim;
    font-weight: 600;
}

/// Column header strip above a ListView. Fill it with HeaderCells.
export component TableHeader inherits Rectangle {
    height: 28px;
    background: SigmaTheme.surface-raised;
    border-radius: 4px;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;
        @children
    }
}

/// Table row with the standard hover and selection washes.
export component TableRow inherits Rectangle {
    in property <bool> selected: false;
    in property <bool> hoverable: true;
    callback clicked <=> touch.clicked;
    height: SigmaTheme.row-height;
    background: root.selected
        ? SigmaTheme.accent.transparentize(0.85)
        : (root.hoverable && touch.has-hover ? SigmaTheme.surface-raised : transparent);
    touch := TouchArea {
        enabled: root.hoverable;
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;
        @children
    }
}

/// Centered placeholder for lists with nothing to show yet.
export component EmptyState inherits VerticalLayout {
    in property <string> message;
    in property <string> hint: "";
    alignment: center;
    spacing: 4px;
    Text {
        text: root.message;
        color: SigmaTheme.text-dim;
        horizontal-alignment: center;
        wrap: word-wrap;
    }
    if root.hint != "": Text {
        text: root.hint;
        color: SigmaTheme.text-dim;
        font-size: SigmaTheme.font-size-small;
        horizontal-alignment: center;
        wrap: word-wrap;
        opacity: 0.7;
    }
}

export component ToolbarButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> enabled: true;
    /// Destructive action: red accents instead of blue.
    in property <bool> danger: false;
    callback clicked;
    height: 32px;
    opacity: root.enabled ? 1.0 : 0.45;
    background: root.selected
        ? (root.danger ? SigmaTheme.accent-red : SigmaTheme.accent).transparentize(0.75)
        : (touch.pressed && root.enabled ? SigmaTheme.surface-raised : SigmaTheme.surface);
    border-radius: 4px;
    border-width: 1px;
    border-color: root.selected || root.danger
        ? (root.danger ? SigmaTheme.accent-red : SigmaTheme.accent)
        : SigmaTheme.border;
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: center;
        Text {
            text: root.label;
            color: root.danger
                ? SigmaTheme.accent-red
                : (root.selected ? SigmaTheme.accent : SigmaTheme.text);
            vertical-alignment: center;
        }
    }
}

/// Header load button. Green wash once a file is loaded, neutral before.
/// Single line: "MDF4: file.mf4" / "DBC: —"
export component FileLoadButton inherits Rectangle {
    in property <string> label;
    in property <string> filename: "";
    in property <bool> loaded: false;
    callback clicked <=> touch.clicked;

    private property <string> display-text:
        root.label + ": " + (root.filename == "" ? "—" : root.filename);

    // Sized to content but capped, so long filenames elide instead of
    // pushing the button strip into the tab bar.
    width: clamp(label-text.preferred-width + 24px, 120px, 220px);
    height: 28px;
    background: root.loaded
        ? (touch.pressed
            ? SigmaTheme.accent-green.transparentize(0.55)
            : SigmaTheme.accent-green.transparentize(0.7))
        : (touch.pressed ? SigmaTheme.surface-raised : SigmaTheme.surface);
    border-radius: 4px;
    border-width: 1px;
    border-color: root.loaded ? SigmaTheme.accent-green : SigmaTheme.border;
    clip: true;
    touch := TouchArea {
        width: 100%;
        height: 100%;
    }
    HorizontalLayout {
        width: 100%;
        height: 100%;
        padding-left: 10px;
        padding-right: 10px;
        alignment: center;
        label-text := Text {
            text: root.display-text;
            color: root.loaded ? SigmaTheme.accent-green : SigmaTheme.text-dim;
            horizontal-alignment: center;
            vertical-alignment: center;
            font-weight: 600;
            font-size: SigmaTheme.font-size-small;
            overflow: elide;
        }
    }
}

/// Compact labeled field: LineEdit when editable, plain text when read-only.
export component CompactField inherits VerticalLayout {
    in property <string> label;
    in-out property <string> text;
    in property <bool> read-only: false;
    callback edited;
    spacing: 2px;
    alignment: start;
    vertical-stretch: 0;

    Text {
        text: root.label;
        color: SigmaTheme.text-dim;
        font-size: SigmaTheme.font-size-small;
        height: 14px;
    }
    if root.read-only: Text {
        text: root.text;
        color: SigmaTheme.text;
        font-size: SigmaTheme.font-size-small;
        height: 24px;
        vertical-alignment: center;
        overflow: elide;
    }
    if !root.read-only: LineEdit {
        text <=> root.text;
        height: 24px;
        font-size: SigmaTheme.font-size-small;
        edited => { root.edited(); }
    }
}

export component StatusChip inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <brush> value-color: SigmaTheme.text-dim;
    height: 24px;
    background: SigmaTheme.surface;
    border-radius: 4px;
    border-width: 1px;
    border-color: SigmaTheme.border;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        if root.label != "": Text { text: root.label; color: SigmaTheme.text-dim; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
        Text { text: root.value; color: root.value-color; font-size: SigmaTheme.font-size-small; vertical-alignment: center; }
    }
}
